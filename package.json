    "bcryptjs": "^3.0.3",
    "bullmq": "^5.78.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.40.0",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "lucide-react": "^1.20.0",
    "next": "16.2.7",
